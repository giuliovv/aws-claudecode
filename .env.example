# Telegram
TELEGRAM_BOT_TOKEN=          # Token from @BotFather for the central routing bot
TELEGRAM_BOT_HANDLE=         # e.g. my_claudecode_bot (without @)

# AWS — populated automatically after cdk deploy (see stack outputs)
AWS_REGION=us-east-1
ACCOUNT_ID=854656252703
ECS_CLUSTER=claudecode
EFS_FS_ID=                   # from ClaudeCodeStack output: EfsId
TASK_SG_ID=                  # from ClaudeCodeStack output: TaskSgId
REPO_URI=                    # from ClaudeCodeStack output: RepoUri
TASK_ROLE_ARN=               # from ClaudeCodeStack output: TaskRoleArn
EXEC_ROLE_ARN=arn:aws:iam::854656252703:role/ecsTaskExecutionRole
DYNAMO_TABLE=claudecode-users

# Comma-separated public subnet IDs (all 6 default VPC subnets work)
SUBNET_IDS=subnet-00ef452a9147da192,subnet-0b799a4832af70f5b,subnet-01497e4f428a93b98
